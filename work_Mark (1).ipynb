import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import os
from google.colab import drive

# 1. SETUP
drive.mount('/content/drive')
path = "/content/drive/MyDrive/ProgettoMark/"

if not os.path.exists(path):
    os.makedirs(path)

# 2. GENERAZIONE DATI
n_rows = 2000000
data = {
    'ID_Transazione': range(1, n_rows + 1),
    'Data': pd.to_datetime(np.random.choice(pd.date_range('2025-01-01', '2026-01-01'), n_rows)),
    'Cliente_Paese': np.random.choice(['Italia', 'Italy', 'it', 'Francia', 'france', 'FR', 'Germania', 'DE'], n_rows),
    'Prodotto_ID': np.random.choice(['E-Chrg-01', 'E-Chrg-02', 'Fast-Ch'], n_rows),
    'Importo_Lordo': np.random.uniform(10, 500, n_rows),
    'Stato_Pagamento': np.random.choice(['Paid', 'Sospeso', 'null', 'pagato'], n_rows)
}
df = pd.DataFrame(data)

# Controllo iniziale
print(df.head(100))

# 3. PULIZIA DATI
df['Data'] = pd.to_datetime(df['Data'], errors='coerce')
df = df.dropna(subset=['Data'])

mappa_paesi = {'france': 'Francia', 'FR': 'Francia', 'Italy': 'Italia', 'it': 'Italia', 'DE': 'Germania'}
df['Cliente_Paese'] = df['Cliente_Paese'].replace(mappa_paesi)

df['Prodotto_ID'] = df['Prodotto_ID'].str.upper()
df['Importo_Lordo'] = df['Importo_Lordo'].round(2)

mappa_pagamenti = {'Paid': 'PAGATO', 'pagato': 'PAGATO', 'Sospeso': 'SOSPESO'}
df['Stato_Pagamento'] = df['Stato_Pagamento'].replace(mappa_pagamenti).fillna('DA VERIFICARE')

# Salvataggio
df.to_csv(os.path.join(path, "DatiPulitiMark.csv"), index=False)

# Controllo finale
print(df.head(100))

# 4. ANALISI E GRAFICI
pd.options.display.float_format = '{:.2f}'.format

# Grafico: Incassi mensili
df['Mese'] = df['Data'].dt.month
df.groupby('Mese')['Importo_Lordo'].sum().plot(kind='line', marker='o', color='green', figsize=(10,5))
plt.title('Incassi Mensili')
plt.grid(True)
plt.show()

# Grafico: Media per prodotto
df.groupby('Prodotto_ID')['Importo_Lordo'].mean().sort_values(ascending=False).plot(kind='bar', color=['#34a853', '#4285f4', '#fbbc05'], figsize=(8,5))
plt.title('Media Incasso Prodotto')
plt.show()

# Grafico: Stato pagamenti
df.groupby('Stato_Pagamento')['Importo_Lordo'].sum().plot(kind='pie', autopct='%1.1f%%', figsize=(7,7))
plt.title('Stato Pagamenti')
plt.ylabel('')
plt.show()

# 5. BILANCIO
totale = df['Importo_Lordo'].sum()
pagato = df[df['Stato_Pagamento'] == 'PAGATO']['Importo_Lordo'].sum()
scarto = ((totale - pagato) / totale) * 100

print(f"Totale registrato: {totale:,.2f} €")
print(f"Scarto percentuale: {scarto:.2f}%")
